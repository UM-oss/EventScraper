# Event Scraper konfiguracija
# Skopiraj v .env in prilagodi.

# === BAZA PODATKOV ===
# SQLite (privzeto, razvoj):
# EVENT_SCRAPER_DATABASE_URL=sqlite:///data/events.db
#
# PostgreSQL (produkcija):
EVENT_SCRAPER_DATABASE_URL=postgresql://event_scraper:event_scraper_pwd@localhost:5432/event_scraper

# Pool nastavitve (samo PostgreSQL)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# === SCHEDULER ===
# 1 = vključi avtomatsko periodično scrapanje
EVENT_SCRAPER_SCHEDULER=0
EVENT_SCRAPER_SCHEDULE_INTERVAL=60   # minutes
EVENT_SCRAPER_SCHEDULE_DAYS=30       # look-ahead dni
EVENT_SCRAPER_SCHEDULE_AT_START=0    # 1 = poženi enkrat ob startupu

# === DEDUPLIKACIJA (thresholdi 0-100) ===
DEDUP_TH_SAME_TIME=60
DEDUP_TH_SAME_LOC=70
DEDUP_TH_TITLE_ONLY=80
DEDUP_TH_LOCATION=70

# === LOGIRANJE ===
LOG_LEVEL=INFO
LOG_JSON=0   # 1 = JSON format (produkcija)

# === FLASK ===
FLASK_DEBUG=0
PORT=8080
SESSION_SECURE=0   # 1 = HTTPS only cookies (produkcija)

# === KONFIGURACIJA ===
EVENT_SCRAPER_VALIDATE=1   # validiraj YAML-e ob startupu
EVENT_SCRAPER_INIT_DB=0    # 1 = init_db() namesto Alembic-a

# === GEMINI API (za AI generiranje opisov) ===
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
